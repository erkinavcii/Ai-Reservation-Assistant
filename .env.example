# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Model to use: deepseek-chat (which corresponds to V4 models or the main chat endpoint)
# Note: For DeepSeek API, deepseek-chat is typically the endpoint for general and coding chat.
# They also support deepseek-coder.
DEEPSEEK_MODEL=deepseek-chat

# Server Configuration
PORT=8000
HOST=0.0.0.0
